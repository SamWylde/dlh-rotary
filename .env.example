# Neon / Postgres connection string (canonical; Vercel Neon integration sets this automatically)
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=verify-full
# DATABASE_URI is also accepted as a fallback alias

# Payload auth/JWT secret
PAYLOAD_SECRET=generate-a-random-32-char-string

# Public site URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob token
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxx

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@dlhrotary.org
DEFAULT_FROM_NAME=Rotary Club of Downtown Lock Haven

# Optional seed controls
RUN_SEED_ON_INIT=false
SEED_FORCE=false
SEED_SECRET=choose-a-seed-route-secret
SEED_DEFAULT_PASSWORD=change-me-before-using-seed
SEED_ADMIN_EMAIL=admin@example.org
SEED_ADMIN_NAME=Site Admin
